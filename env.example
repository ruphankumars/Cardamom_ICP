PORT=3000

# ========== Google Sheets (legacy, being phased out) ==========
# Replace with the ID from your Google Sheet URL
SPREADSHEET_ID=your-spreadsheet-id

# ========== Firebase Firestore (new backend) ==========
# Get these from Firebase Console > Project Settings > Service Accounts
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ========== Feature Flags (per-module migration) ==========
# Set to "true" to use Firestore for that module. Default is Google Sheets.
# FB_ALL=true          # Override: enable Firestore for ALL modules at once
FB_USERS=false
FB_APPROVALS=false
# FB_CLIENT_REQUESTS=false
# FB_ORDERS=false
# FB_STOCK=false
# FB_TASKS=false
# FB_ATTENDANCE=false
# FB_EXPENSES=false
# FB_GATEPASSES=false
# FB_ANALYTICS=false
