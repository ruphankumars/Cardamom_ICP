PORT=3000

# ========== ICP / Canister Configuration ==========
# These are set automatically when running via dfx
# CANISTER_ID=
# DFX_NETWORK=local

# ========== Authentication ==========
JWT_SECRET=your-jwt-secret-here
NODE_ENV=development

# ========== Google Sheets (stock calculation engine) ==========
# Only needed if you use the Google Sheets stock calc integration
SPREADSHEET_ID=your-spreadsheet-id

# ========== WhatsApp Cloud API (Meta) ==========
WHATSAPP_TOKEN=your-meta-whatsapp-cloud-api-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id

# ========== Performance ==========
# Set to "false" to disable pagination and revert to full collection loads
PAGINATED_ENDPOINTS=true
