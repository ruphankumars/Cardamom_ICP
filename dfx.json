{
  "version": 1,
  "dfx": "0.31.0",
  "networks": {
    "ic": {
      "providers": ["https://ic0.app"],
      "type": "persistent"
    },
    "local": {
      "bind": "127.0.0.1:4943",
      "type": "ephemeral"
    }
  },
  "canisters": {
    "backend": {
      "type": "azle",
      "main": "src/backend/index.ts",
      "custom": {
        "experimental": true,
        "esm_externals": [
          "child_process",
          "node:child_process",
          "node:fs",
          "node:path",
          "node:url",
          "node:buffer",
          "node:crypto",
          "node:stream",
          "node:events",
          "node:util",
          "node:os",
          "node:http",
          "node:process",
          "node:querystring",
          "node:string_decoder",
          "node:assert",
          "node:https",
          "node:zlib",
          "constants",
          "http2",
          "tls",
          "glob",
          "minipass",
          "node-fetch",
          "fetch-blob",
          "formdata-polyfill",
          "pdfkit",
          "fontkit",
          "jimp",
          "sharp"
        ],
        "env": [
          "JWT_SECRET",
          "NODE_ENV",
          "META_WHATSAPP_TOKEN",
          "META_WHATSAPP_PHONE_ID",
          "META_WHATSAPP_SYGT_PHONE_ID",
          "GOOGLE_SERVICE_ACCOUNT_EMAIL",
          "GOOGLE_PRIVATE_KEY",
          "OUTSTANDING_SYGT_SHEET_ID",
          "OUTSTANDING_ESPL_SHEET_ID",
          "SPREADSHEET_ID",
          "PAGINATED_ENDPOINTS",
          "LOGO_URL"
        ]
      }
    },
    "frontend": {
      "type": "assets",
      "source": ["cardamom_app/build/web"],
      "dependencies": ["backend"]
    }
  }
}
